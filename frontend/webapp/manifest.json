{
  "sap.app": {
    "id": "ui5.app",
    "type": "application"
  },
  "sap.ui5": {
    "rootView": {
      "viewName": "ui5.app.view.App",
      "type": "XML"
    },
    "dependencies": {
      "libs": {
        "sap.m": {}
      }
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "viewPath": "ui5.app.view",
        "controlId": "rootApp",
        "controlAggregation": "pages"
      },
      "routes": [
        {
          "pattern": "",
          "name": "list",
          "target": "list"
        },
        {
          "pattern": "detail/{id}",
          "name": "detail",
          "target": "detail"
        }
      ],
      "targets": {
        "list": {
          "viewName": "List"
        },
        "detail": {
          "viewName": "Detail"
        }
      }
    }
  }
}
